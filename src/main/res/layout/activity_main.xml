<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#1565C0">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SafeWiFi"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="연결하기 전, 반드시 확인하세요"
            android:textColor="#BBDEFB"
            android:textSize="13sp"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingLeft="24dp"
        android:paddingRight="24dp">

        <Button
            android:id="@+id/btnCurrentWifi"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="현재 Wi-Fi 보안 분석"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0" />

        <Button
            android:id="@+id/btnNearbyWifi"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="16dp"
            android:text="주변 Wi-Fi 스캔"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32" />

        <Button
            android:id="@+id/btnHistory"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="검사 기록 보기"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5C6BC0" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="모든 데이터는 기기 내부에만 저장됩니다"
        android:textColor="#9E9E9E"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingBottom="20dp" />

</LinearLayout>